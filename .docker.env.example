# Docker Hub Push Configuration (.env.docker)
# This file is used when running: ./build_image.sh --docker
#
# It should contain a TAG_LIST with tags for both:
#   - Local registry (for local testing)
#   - Docker Hub registry (for public distribution)
#
# Before using --docker, ensure you're logged in to Docker Hub:
#   docker login
#
# EXAMPLE:
# TAG_LIST="--tag registry.example.local:443/broken_shadows:latest \
#           --tag registry.example.local:443/broken_shadows:${DATE} \
#           --tag myuser/broken_shadows:latest \
#           --tag myuser/broken_shadows:${DATE}"
#
# Or with environment variable substitution:
# DATE=$(date +"%Y%m%d")
# TAG_LIST="--tag registry.example.local:443/broken_shadows:${DATE} \
#           --tag registry.example.local:443/broken_shadows:latest \
#           --tag myuser/broken-shadows:${DATE} \
#           --tag myuser/broken-shadows:latest"
